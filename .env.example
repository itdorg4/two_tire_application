# Copy to .env and adjust. Loaded by docker-compose and the systemd service.

# App admin login
ADMIN_USER=admin
ADMIN_PASSWORD=admin
SECRET_KEY=change-me-in-prod

# MySQL (data tier)
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=user_profile
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword
# Only used by the Docker MySQL container:
MYSQL_ROOT_PASSWORD=rootpassword
